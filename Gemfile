source "https://rubygems.org"

# The github-pages gem pins Jekyll and every plugin to the exact versions
# GitHub Pages runs, so a local build matches production. It also pulls in the
# default plugins this site relies on (optional-front-matter, relative-links,
# readme-index, titles-from-headings).
gem "github-pages", group: :jekyll_plugins

# Windows / JRuby helpers (harmless elsewhere)
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :mswin, :x64_mingw]

# Faster local rebuilds on some platforms
gem "webrick", "~> 1.8"
