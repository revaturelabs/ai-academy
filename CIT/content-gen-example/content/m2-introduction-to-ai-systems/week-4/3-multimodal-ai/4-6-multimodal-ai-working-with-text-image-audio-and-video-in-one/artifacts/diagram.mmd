flowchart LR
    T["<b>Text</b><br/><span style='font-size:12px;color:#6d28d9'>typed words</span>"]:::start
    I["<b>Image</b><br/><span style='font-size:12px;color:#6d28d9'>photo or picture</span>"]:::start
    A["<b>Audio</b><br/><span style='font-size:12px;color:#6d28d9'>spoken sound</span>"]:::start
    V["<b>Video</b><br/><span style='font-size:12px;color:#6d28d9'>moving images</span>"]:::start

    ENC["<b>Modality Encoders</b><br/><span style='font-size:12px;color:#6d28d9'>one per input type — converts each to numbers</span>"]:::auto

    SRS["<b>Shared Representation Space</b><br/><span style='font-size:12px;color:#6d28d9'>common internal language for all modalities</span>"]:::act

    REASON["<b>Reasoning Engine</b><br/><span style='font-size:12px;color:#6d28d9'>thinks across all inputs together</span>"]:::auto

    OUT["<b>Output Response</b><br/><span style='font-size:12px;color:#6d28d9'>typically text</span>"]:::done

    T --> ENC
    I --> ENC
    A --> ENC
    V --> ENC

    ENC --> SRS
    SRS --> REASON
    REASON --> OUT

