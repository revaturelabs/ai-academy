---
flowchart LR
    RUBRIC["<b>Rubric Scores</b><br/><span style='font-size:12px;color:#6d28d9'>Criterion · weight · score per tool</span>"]
    TABLE["<b>Findings Summary Table</b><br/><span style='font-size:12px;color:#6d28d9'>Weighted totals · side-by-side differences</span>"]
    CRITERIA["<b>Deciding Criteria</b><br/><span style='font-size:12px;color:#6d28d9'>Largest gaps · highest-weighted items</span>"]
    ANCHOR["<b>Evidence Anchor</b><br/><span style='font-size:12px;color:#6d28d9'>Score + descriptor + test observation</span>"]
    TRADEOFFS["<b>Trade-offs Noted</b><br/><span style='font-size:12px;color:#6d28d9'>Where the weaker tool still wins</span>"]
    REC["<b>Recommendation Statement</b><br/><span style='font-size:12px;color:#6d28d9'>Conclusion cited to evidence, not opinion</span>"]
    LIMITS["<b>Limitations Added</b><br/><span style='font-size:12px;color:#6d28d9'>Conditions under which advice changes</span>"]

    RUBRIC --> TABLE --> CRITERIA --> ANCHOR --> TRADEOFFS --> REC --> LIMITS

    classDef start fill:#a5d8ff,stroke:#4a9eed,stroke-width:2px,color:#1e3a5f
