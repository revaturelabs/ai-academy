---
title: "Four-Step Tool-Use Cycle"
theme: base
themeVariables:
  primaryColor: "#a5d8ff"
  primaryBorderColor: "#4a9eed"
  lineColor: "#555"
config:
  flowchart:
    htmlLabels: true
    curve: basis
    rankSpacing: 55
    nodeSpacing: 40
---
flowchart LR
    USER_IN["<b>User Message</b><br/><span style='font-size:12px;color:#6d28d9'>A question or request</span>"]
    DECIDE["<b>LLM Decides</b><br/><span style='font-size:12px;color:#6d28d9'>Step 1 — Is a tool needed?</span>"]
    ROUTER["<b>Routing Software</b><br/><span style='font-size:12px;color:#6d28d9'>Step 2 — Receives structured request<br/>LLM never calls tools directly</span>"]
    EXECUTE["<b>External Tool Runs</b><br/><span style='font-size:12px;color:#6d28d9'>Step 3 — Search · Calculator · Code Runner</span>"]
    RETURN["<b>LLM Gets Result</b><br/><span style='font-size:12px;color:#6d28d9'>Step 4 — Result returned; LLM is unpaused</span>"]
    USER_OUT["<b>Final Answer</b><br/><span style='font-size:12px;color:#6d28d9'>Composed reply delivered to user</span>"]

    USER_IN --> DECIDE
    DECIDE -->|"structured request"| ROUTER
    ROUTER -->|"executes"| EXECUTE
    EXECUTE -->|"result"| RETURN
    RETURN --> USER_OUT

    classDef start fill:#a5d8ff,stroke:#4a9eed,stroke-width:2px,color:#1e3a5f
    classDef auto  fill:#d0bfff,stroke:#8b5cf6,stroke-width:2px,color:#2e1065
    classDef act   fill:#a5d8ff,stroke:#4a9eed,stroke-width:2px,color:#1e3a5f
    classDef done  fill:#b2f2bb,stroke:#22c55e,stroke-width:2px,color:#14532d
    classDef hitl  fill:#fff3bf,stroke:#f59e0b,stroke-width:3px,color:#78350f
    classDef ghost fill:none,stroke:none,color:#6d28d9

    class USER_IN start
    class DECIDE,ROUTER,RETURN auto
    class EXECUTE act
    class USER_OUT done
