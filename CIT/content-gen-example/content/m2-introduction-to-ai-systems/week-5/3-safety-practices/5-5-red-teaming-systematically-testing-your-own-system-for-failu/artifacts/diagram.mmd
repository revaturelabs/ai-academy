---
title: "Red-teaming runs before deployment, after updates, and ongoing"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 55
    rankSpacing: 70
---
flowchart LR
    plan["<b>Plan</b><br><span style='font-size:12px;color:#6d28d9'>pick failure categories</span>"]
    attack["<b>Attack</b><br><span style='font-size:12px;color:#6d28d9'>fire adversarial inputs</span>"]
    find["<b>Find</b><br><span style='font-size:12px;color:#6d28d9'>record each weakness</span>"]
    fix["<b>Fix</b><br><span style='font-size:12px;color:#6d28d9'>patch the weakness</span>"]
    retest["<b>Re-test</b><br><span style='font-size:12px;color:#6d28d9'>regression: confirm fix</span>"]

    plan --> attack
    attack --> find
    find --> fix
    fix --> retest
    retest -->|repeat| attack

    plan:::start
    attack:::auto
    find:::auto
    fix:::auto
    retest:::done

    classDef start fill:#a5d8ff,stroke:#4a9eed,color:#1e3a5f
    classDef auto fill:#d0bfff,stroke:#8b5cf6,color:#2e1065
    classDef done fill:#b2f2bb,stroke:#22c55e,color:#14532d
