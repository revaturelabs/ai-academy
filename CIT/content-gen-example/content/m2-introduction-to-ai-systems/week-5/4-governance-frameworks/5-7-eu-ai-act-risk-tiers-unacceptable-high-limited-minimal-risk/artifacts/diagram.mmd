---
title: "EU AI Act — Four Risk Tiers (top = highest risk, fewest systems; base = lowest risk, most systems)"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
    fontSize: "16px"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 50
    rankSpacing: 40
---
flowchart TB
    T1["<b>Unacceptable</b><br><span style='font-size:13px;color:#6d28d9'>Banned outright</span><br><span style='font-size:12px;color:#444'>Example: social scoring</span><br><span style='font-size:11px;color:#888'>very few systems</span>"]
    T2["<b>High risk</b><br><span style='font-size:13px;color:#6d28d9'>Allowed, but heavily regulated</span><br><span style='font-size:12px;color:#444'>Example: hiring or healthcare AI</span>"]
    T3["<b>Limited risk</b><br><span style='font-size:13px;color:#6d28d9'>Allowed; transparency required to disclose AI</span><br><span style='font-size:12px;color:#444'>Example: a chatbot must disclose it is AI</span>"]
    T4["<b>Minimal risk</b><br><span style='font-size:13px;color:#6d28d9'>Allowed freely; no mandatory rules under the Act at all</span><br><span style='font-size:12px;color:#444'>Example: spam filter, video-game AI</span><br><span style='font-size:11px;color:#888'>most systems live here</span>"]

    T1 --> T2 --> T3 --> T4

    classDef banned fill:#ffc9c9,stroke:#e03131,stroke-width:3px,color:#000;
    classDef high fill:#ffd8a8,stroke:#f59e0b,stroke-width:2px,color:#000;
    classDef limited fill:#ffec99,stroke:#eab308,stroke-width:2px,color:#000;
    classDef minimal fill:#b2f2bb,stroke:#22c55e,stroke-width:2px,color:#000;

    class T1 banned;
    class T2 high;
    class T3 limited;
    class T4 minimal;
