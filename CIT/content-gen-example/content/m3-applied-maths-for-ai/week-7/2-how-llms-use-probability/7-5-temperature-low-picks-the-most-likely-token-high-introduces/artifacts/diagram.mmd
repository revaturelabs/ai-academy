---
title: Temperature controls how spread out the probability distribution is
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 40
    rankSpacing: 50
---
flowchart LR
    LOW["<b>Low Temperature</b><br/><span style='font-size:12px;color:#6d28d9'>e.g. 0.2 — sharp distribution<br/>blue 97%, clear 2%, others ~0%</span>"]
    MID["<b>Neutral Temperature</b><br/><span style='font-size:12px;color:#6d28d9'>e.g. 1.0 — balanced spread<br/>blue 55%, clear 18%, dark 12%</span>"]
    HIGH["<b>High Temperature</b><br/><span style='font-size:12px;color:#6d28d9'>e.g. 1.5 — flat distribution<br/>blue 36%, clear 20%, dark 17%</span>"]

    R_LOW["<b>Reliable</b><br/><span style='font-size:12px;color:#6d28d9'>Same token picked every time<br/>Best for customer service</span>"]
    R_MID["<b>Balanced</b><br/><span style='font-size:12px;color:#6d28d9'>Default API setting<br/>General-purpose output</span>"]
    R_HIGH["<b>Varied</b><br/><span style='font-size:12px;color:#6d28d9'>Different token each time<br/>Best for creative writing</span>"]

    LOW --> R_LOW
    MID --> R_MID
    HIGH --> R_HIGH

    classDef sharp fill:#a5d8ff,stroke:#4a9eed,color:#1a1a1a
    classDef neutral fill:#d0bfff,stroke:#8b5cf6,color:#1a1a1a
    classDef flat fill:#fff3bf,stroke:#f59e0b,color:#1a1a1a
    classDef done fill:#b2f2bb,stroke:#22c55e,color:#1a1a1a

    class LOW sharp
    class MID neutral
    class HIGH flat
    class R_LOW,R_MID,R_HIGH done
