%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#a5d8ff", "primaryBorderColor": "#4a9eed", "lineColor": "#555", "fontFamily": "sans-serif"}, "flowchart": {"htmlLabels": true, "curve": "basis", "nodeSpacing": 60, "rankSpacing": 80}}}%%
flowchart TB
    AXIS_TOP["<b>ACTUAL TRUTH (Ground Truth)</b><br/><span style='font-size:11px;color:#6d28d9'>What the item really is — determined before the model runs</span>"]

    subgraph MATRIX["2x2 Confusion Matrix — Predicted vs Actual"]
        direction TB

        subgraph ROW_POS["PREDICTED: Positive  |  Precision = TP ÷ (TP + FP)"]
            direction LR
            TP["<b>True Positive (TP)</b><br/>Model: Positive  Actual: Positive<br/><span style='font-size:11px;color:#166534'>Correct flag — caught a real case</span>"]
            FP["<b>False Positive (FP)</b><br/>Model: Positive  Actual: Negative<br/><span style='font-size:11px;color:#991b1b'>False alarm — flagged when it should not have</span>"]
        end

        subgraph ROW_NEG["PREDICTED: Negative  |  Recall = TP ÷ (TP + FN)"]
            direction LR
            FN["<b>False Negative (FN)</b><br/>Model: Negative  Actual: Positive<br/><span style='font-size:11px;color:#991b1b'>Missed — real case slipped through</span>"]
            TN["<b>True Negative (TN)</b><br/>Model: Negative  Actual: Negative<br/><span style='font-size:11px;color:#166534'>Correct non-flag — rightly left alone</span>"]
        end
    end

    ACCURACY["<b>Accuracy uses ALL FOUR cells equally</b><br/><span style='font-size:11px;color:#6d28d9'>(TP + TN) / total — diagonal = correct predictions, off-diagonal = mistakes<br/>A large TN can push accuracy to 95% even when TP = 0</span>"]

    AXIS_TOP --> ROW_POS
    AXIS_TOP --> ROW_NEG
    MATRIX --> ACCURACY

    classDef correct fill:#b2f2bb,stroke:#22c55e,stroke-width:2px,color:#14532d
    classDef error fill:#fecaca,stroke:#ef4444,stroke-width:2px,color:#7f1d1d
    classDef ghost fill:none,stroke:none,color:#6d28d9
    classDef axislabel fill:#e0f2fe,stroke:#4a9eed,stroke-width:1px,color:#0c4a6e

    class TP,TN correct
    class FP,FN error
    class ACCURACY ghost
    class AXIS_TOP axislabel
