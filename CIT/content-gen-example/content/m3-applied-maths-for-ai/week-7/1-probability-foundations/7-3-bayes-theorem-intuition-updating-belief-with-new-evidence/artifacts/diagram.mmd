---
title: Bayesian Belief Updating
theme: base
themeVariables:
  primaryColor: "#a5d8ff"
  primaryBorderColor: "#4a9eed"
  lineColor: "#555"
flowchart:
  htmlLabels: true
  curve: basis
---
flowchart LR
    PRIOR["<b>Prior Belief</b><br/><span style='font-size:12px;color:#6d28d9'>P(A) — starting belief<br/>before evidence</span>"]:::start

    OBSERVE["<b>Observe Evidence</b><br/><span style='font-size:12px;color:#6d28d9'>Event B occurs<br/>e.g. dark clouds appear</span>"]:::auto

    UPDATE["<b>Bayes Update</b><br/><span style='font-size:12px;color:#6d28d9'>Weigh likelihood P(B|A)<br/>against overall P(B)</span>"]:::auto

    POSTERIOR["<b>Posterior Belief</b><br/><span style='font-size:12px;color:#6d28d9'>P(A|B) — updated belief<br/>after seeing evidence</span>"]:::done

    CYCLE["<b>Cycle Repeats</b><br/><span style='font-size:12px;color:#6d28d9'>Posterior becomes<br/>new Prior next round</span>"]:::act

    PRIOR -->|"set P(A)"| OBSERVE
    OBSERVE -->|"likelihood P(B|A)"| UPDATE
    UPDATE -->|"divide by P(B)"| POSTERIOR
    POSTERIOR -->|"becomes new Prior"| CYCLE
    CYCLE -.->|"new starting belief"| PRIOR

    classDef start fill:#a5d8ff,stroke:#4a9eed
    classDef auto fill:#d0bfff,stroke:#8b5cf6
    classDef done fill:#b2f2bb,stroke:#22c55e
    classDef act fill:#a5d8ff,stroke:#4a9eed
    classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:3
