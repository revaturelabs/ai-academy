---
title: "Reliability diagram — x = stated confidence, y = observed accuracy"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 60
    rankSpacing: 55
---
flowchart TB
  diag["<b>On the diagonal</b><br/><span style='font-size:12px;color:#14532d'>stated confidence = observed accuracy — well-calibrated, trustworthy</span>"]
  above["<b>Above the diagonal</b><br/><span style='font-size:12px;color:#1e3a5f'>Underconfident: says 0.60, right 0.80 — right more often than it claims</span>"]
  below["<b>Below the diagonal</b><br/><span style='font-size:12px;color:#7f1d1d'>Overconfident: says 0.90, right 0.70 — the dangerous case</span>"]

  above -->|"more accurate than it claims"| diag
  diag -->|"less accurate than it claims"| below

  class diag done
  class above under
  class below over
  classDef done fill:#b2f2bb,stroke:#22c55e,stroke-width:3px,color:#14532d
  classDef under fill:#a5d8ff,stroke:#4a9eed,color:#1e3a5f
  classDef over fill:#ffc9c9,stroke:#e03131,stroke-width:3px,color:#7f1d1d
