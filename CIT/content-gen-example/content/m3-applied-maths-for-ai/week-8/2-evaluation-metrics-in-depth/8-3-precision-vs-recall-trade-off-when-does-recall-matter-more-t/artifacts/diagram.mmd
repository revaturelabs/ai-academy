---
title: "The threshold dial: precision vs recall trade-off"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 55
    rankSpacing: 70
---
flowchart TD
  thr["<b>Threshold dial</b><br/><span style='font-size:12px;color:#6d28d9'>cut-off the model compares its confidence score to</span>"]

  subgraph LOW["Slide threshold DOWN (flag eagerly)"]
    direction TB
    rec["<b>Recall up</b><br/><span style='font-size:12px;color:#6d28d9'>catches more real cases</span>"]
    fp["<b>More false positives</b><br/><span style='font-size:12px;color:#6d28d9'>false alarm: flagged wrongly</span>"]
    rec -->|"so precision drops"| fp
  end

  subgraph HIGH["Slide threshold UP (flag only when sure)"]
    direction TB
    prec["<b>Precision up</b><br/><span style='font-size:12px;color:#6d28d9'>flags are more trustworthy</span>"]
    fn["<b>More false negatives</b><br/><span style='font-size:12px;color:#6d28d9'>miss: failed to flag a real case</span>"]
    prec -->|"so recall drops"| fn
  end

  thr -->|"lower it"| rec
  thr -->|"raise it"| prec

  thr:::start
  rec:::done
  prec:::done
  fp:::hitl
  fn:::hitl

  classDef start fill:#a5d8ff,stroke:#4a9eed,stroke-width:2px;
  classDef done fill:#b2f2bb,stroke:#22c55e,stroke-width:2px;
  classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:2px;
