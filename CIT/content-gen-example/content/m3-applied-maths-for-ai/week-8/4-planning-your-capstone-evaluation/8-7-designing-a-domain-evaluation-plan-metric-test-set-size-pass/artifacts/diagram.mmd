---
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 55
    rankSpacing: 60
title: A domain evaluation plan — decided in advance
---
flowchart LR
    mistake["<b>Name the costly mistake</b><br><span style='font-size:12px;color:#6d28d9'>which wrong answer hurts most?</span>"]
    metric["<b>Choose the metric</b><br><span style='font-size:12px;color:#6d28d9'>recall / precision / F1 / accuracy<br>(+ calibration check)</span>"]
    testset["<b>Size the test set</b><br><span style='font-size:12px;color:#6d28d9'>held-out, representative</span>"]
    threshold["<b>Set pass/fail threshold</b><br><span style='font-size:12px;color:#6d28d9'>stake-based, set in advance</span>"]
    compare{"<b>Score vs threshold?</b>"}
    ship["<b>Ship</b>"]
    rework["<b>Rework</b>"]

    mistake --> metric --> testset --> threshold --> compare
    compare -->|"at or above"| ship
    compare -->|"below"| rework

    classDef start fill:#a5d8ff,stroke:#4a9eed,color:#0b2545;
    classDef auto fill:#d0bfff,stroke:#8b5cf6,color:#2e1065;
    classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:3px,color:#3a2a00;
    classDef done fill:#b2f2bb,stroke:#22c55e,color:#052e16;

    class mistake start;
    class metric,testset,threshold auto;
    class compare,rework hitl;
    class ship done;
