---
title: "Same slot order: Position 1=energy, Position 2=tempo, Position 3=mood"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
    edgeLabelBackground: "#ffffff"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 60
    rankSpacing: 80
---
flowchart TD
    subgraph SONGA["Song A  →  [ 0.8,  0.6,  0.3 ]  (identical slot layout)"]
        direction LR
        A1["<b>Position 1</b><br/><span style='font-size:12px;color:#6d28d9'>energy = 0.8</span>"]:::auto
        A2["<b>Position 2</b><br/><span style='font-size:12px;color:#6d28d9'>tempo = 0.6</span>"]:::auto
        A3["<b>Position 3</b><br/><span style='font-size:12px;color:#6d28d9'>mood = 0.3</span>"]:::auto
        A1 --> A2 --> A3
    end

    subgraph SONGB["Song B  →  [ 0.4,  0.9,  0.7 ]  (identical slot layout)"]
        direction LR
        B1["<b>Position 1</b><br/><span style='font-size:12px;color:#6d28d9'>energy = 0.4</span>"]:::done
        B2["<b>Position 2</b><br/><span style='font-size:12px;color:#6d28d9'>tempo = 0.9</span>"]:::done
        B3["<b>Position 3</b><br/><span style='font-size:12px;color:#6d28d9'>mood = 0.7</span>"]:::done
        B1 --> B2 --> B3
    end

    classDef auto fill:#d0bfff,stroke:#8b5cf6,color:#1e293b
    classDef done fill:#b2f2bb,stroke:#22c55e,color:#1e293b
