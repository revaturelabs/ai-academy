---
title: "Vector Arithmetic: king − man + woman ≈ queen"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
---
flowchart LR

  subgraph PANEL_A["Panel A — Gender Direction (parallel arrows)"]
    direction TB
    MAN["<b>man</b><br/><span style='font-size:11px;color:#6d28d9'>male word · point in space</span>"]
    WOMAN["<b>woman</b><br/><span style='font-size:11px;color:#6d28d9'>female word · point in space</span>"]
    KING["<b>king</b><br/><span style='font-size:11px;color:#6d28d9'>male royal · point in space</span>"]
    QUEEN["<b>queen</b><br/><span style='font-size:11px;color:#6d28d9'>female royal · point in space</span>"]
    MAN -->|"gender direction ↑"| WOMAN
    KING -->|"same direction ↑"| QUEEN
  end

  subgraph PANEL_B["Panel B — Analogy Arithmetic Steps"]
    direction TB
    START["<b>Start: king vector</b><br/><span style='font-size:11px;color:#6d28d9'>point in embedding space</span>"]
    STEP1["<b>Subtract man vector</b><br/><span style='font-size:11px;color:#6d28d9'>removes the male component</span>"]
    STEP2["<b>Add woman vector</b><br/><span style='font-size:11px;color:#6d28d9'>adds the female component</span>"]
    RESULT["<b>Landing point ≈ queen</b><br/><span style='font-size:11px;color:#6d28d9'>nearest word in vocabulary</span>"]
    START -->|"− man"| STEP1
    STEP1 -->|"+ woman"| STEP2
    STEP2 -->|"nearest neighbour"| RESULT
  end

  PANEL_A ~~~ PANEL_B

  classDef start fill:#a5d8ff,stroke:#4a9eed
  classDef auto fill:#d0bfff,stroke:#8b5cf6
  classDef done fill:#b2f2bb,stroke:#22c55e

  class MAN,WOMAN,KING,QUEEN start
  class START,STEP1,STEP2 auto
  class RESULT done
