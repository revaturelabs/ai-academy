---
title: "Five Standard Flowchart Shapes — User Age Check"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
---
flowchart TD
    A([<b>START</b><br/><span style='font-size:12px;color:#6d28d9'>terminator — oval</span>]):::start
    B[/<b>Get user_age</b><br/><span style='font-size:12px;color:#6d28d9'>input parallelogram</span>/]:::act
    C{<b>Is user_age ≥ 18?</b><br/><span style='font-size:12px;color:#6d28d9'>decision diamond</span>}:::hitl
    D[<b>Print Registration approved</b><br/><span style='font-size:12px;color:#6d28d9'>process box — rectangle</span>]:::auto
    E[<b>Print Age error message</b><br/><span style='font-size:12px;color:#6d28d9'>process box — rectangle</span>]:::auto
    F([<b>END</b><br/><span style='font-size:12px;color:#6d28d9'>terminator — oval</span>]):::done

    A --> B
    B --> C
    C -->|YES — flowline| D
    C -->|NO — flowline| E
    D --> F
    E --> F

    classDef start fill:#a5d8ff,stroke:#4a9eed
    classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:3px
    classDef auto fill:#d0bfff,stroke:#8b5cf6
    classDef act fill:#a5d8ff,stroke:#4a9eed
    classDef done fill:#b2f2bb,stroke:#22c55e
