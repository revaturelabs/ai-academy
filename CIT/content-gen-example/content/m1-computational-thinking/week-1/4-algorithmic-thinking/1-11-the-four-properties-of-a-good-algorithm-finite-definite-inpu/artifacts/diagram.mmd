---
title: "Well-defined Algorithm — Four-Property Checklist"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 50
    rankSpacing: 60
---
flowchart TB
    entry["<b>Algorithm candidate</b><br/><span style='font-size:12px;color:#6d28d9'>A set of steps to evaluate</span>"]:::start

    check1{"<b>Finite?</b><br/><span style='font-size:12px;color:#6d28d9'>Does it always stop?</span>"}:::auto
    check2{"<b>Definite?</b><br/><span style='font-size:12px;color:#6d28d9'>Is every step clear and precise?</span>"}:::auto
    check3{"<b>Input declared?</b><br/><span style='font-size:12px;color:#6d28d9'>Does it state what data it needs?</span>"}:::auto
    check4{"<b>Output declared?</b><br/><span style='font-size:12px;color:#6d28d9'>Does it produce at least one result?</span>"}:::auto

    pass["<b>Well-defined algorithm</b><br/><span style='font-size:12px;color:#6d28d9'>All four properties satisfied</span>"]:::done
    fail["<b>Not well-defined</b><br/><span style='font-size:12px;color:#6d28d9'>Revise before using</span>"]:::hitl

    entry --> check1
    check1 -- "Yes" --> check2
    check1 -- "No → infinite loop" --> fail
    check2 -- "Yes" --> check3
    check2 -- "No → ambiguity" --> fail
    check3 -- "Yes" --> check4
    check3 -- "No → nothing to work with" --> fail
    check4 -- "Yes" --> pass
    check4 -- "No → no visible effect" --> fail

    classDef start fill:#a5d8ff,stroke:#4a9eed
    classDef auto fill:#d0bfff,stroke:#8b5cf6
    classDef done fill:#b2f2bb,stroke:#22c55e
    classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:3px
