---
title: "Computation = Input → Process → Output (steps must be well-defined)"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 60
    rankSpacing: 60
---
flowchart LR
    %% ── Calculator ───────────────────────────────────────────────
    subgraph CALC["Calculator"]
        direction LR
        B1["<b>Numbers typed</b><br/><span style='font-size:12px;color:#1e40af'>Input</span>"]:::start
        B2["<b>Add / multiply rules</b><br/><span style='font-size:12px;color:#6d28d9'>Process</span>"]:::auto
        B3["<b>Answer displayed</b><br/><span style='font-size:12px;color:#166534'>Output</span>"]:::done
        B1 --> B2 --> B3
    end

    %% ── Vending machine ──────────────────────────────────────────
    subgraph VEND["Vending machine"]
        direction LR
        C1["<b>Coins + button</b><br/><span style='font-size:12px;color:#1e40af'>Input</span>"]:::start
        C2["<b>Check funds and stock</b><br/><span style='font-size:12px;color:#6d28d9'>Process</span>"]:::auto
        C3["<b>Item or coins returned</b><br/><span style='font-size:12px;color:#166534'>Output</span>"]:::done
        C1 --> C2 --> C3
    end

    %% ── Class definitions ────────────────────────────────────────
    classDef start fill:#a5d8ff,stroke:#4a9eed,color:#000
    classDef auto  fill:#d0bfff,stroke:#8b5cf6,color:#000
    classDef done  fill:#b2f2bb,stroke:#22c55e,color:#000
