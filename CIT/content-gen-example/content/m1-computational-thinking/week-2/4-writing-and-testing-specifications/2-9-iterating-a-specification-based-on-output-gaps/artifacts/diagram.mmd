---
title: "Iteration Cycle — fix one gap, retest, repeat"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 55
    rankSpacing: 65
---
flowchart TB
    START["<b>Start: spec to test</b>"]:::start

    TEST["<b>Test the spec</b><br/><span style='font-size:12px;color:#6d28d9'>three-question check</span>"]:::act

    DECISION{"<b>Full pass?</b>"}:::act

    STOP["<b>STOP — spec is done</b>"]:::done

    FDPATCH["<b>Format drift</b><br/><span style='font-size:12px;color:#6d28d9'>Fix: tighten format instruction</span>"]:::hitl

    COPATCH["<b>Constraint overflow</b><br/><span style='font-size:12px;color:#6d28d9'>Fix: add or tighten constraint</span>"]:::hitl

    TDPATCH["<b>Task drift</b><br/><span style='font-size:12px;color:#6d28d9'>Fix: rewrite task statement</span>"]:::hitl

    RETEST["<b>Retest updated spec</b><br/><span style='font-size:12px;color:#6d28d9'>three-question check again</span>"]:::act

    START --> TEST
    TEST --> DECISION
    DECISION -- "Yes" --> STOP
    DECISION -- "Format drift" --> FDPATCH
    DECISION -- "Constraint overflow" --> COPATCH
    DECISION -- "Task drift" --> TDPATCH
    FDPATCH --> RETEST
    COPATCH --> RETEST
    TDPATCH --> RETEST
    RETEST --> DECISION

    classDef start fill:#a5d8ff,stroke:#4a9eed
    classDef act fill:#a5d8ff,stroke:#4a9eed
    classDef done fill:#b2f2bb,stroke:#22c55e
    classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:3px
