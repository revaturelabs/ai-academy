---
flowchart LR
  subgraph HUMAN["Your 30% — Decide and Check"]
    direction TB
    S["<b>Write the Spec</b><br/><span style='font-size:11px;color:#6d28d9'>decide exactly what you need</span>"]:::hitl
    V["<b>Verify Output</b><br/><span style='font-size:11px;color:#6d28d9'>check each part against your spec</span>"]:::hitl
    R["<b>Revise Spec</b><br/><span style='font-size:11px;color:#6d28d9'>fix the gap, resubmit</span>"]:::hitl
  end

  subgraph AI["AI's 70% — Produce"]
    direction TB
    I["<b>AI Implements</b><br/><span style='font-size:11px;color:#6d28d9'>drafts, generates, computes</span>"]:::auto
  end

  D{"<b>Meets spec?</b>"}:::act
  G["<b>Accepted</b><br/><span style='font-size:11px;color:#6d28d9'>output is trustworthy</span>"]:::done

  S --> I
  I --> V
  V --> D
  D -- "Yes" --> G
  D -- "No" --> R
  R --> I

  style HUMAN fill:#fffdf0,stroke:#f59e0b,color:#1a1a1a
  style AI fill:#f5f0ff,stroke:#8b5cf6,color:#1a1a1a

  classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:3px,color:#1a1a1a
