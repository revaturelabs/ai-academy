---
title: "Anatomy of an Anthropic API Request"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
---
graph TB
    KEY["<b>API Key header</b><br/><span style='font-size:12px;color:#6d28d9'>x-api-key: authenticates caller</span>"]
    REQ["<b>API Request object</b><br/><span style='font-size:12px;color:#6d28d9'>sent to Anthropic server</span>"]
    MODEL["<b>model</b><br/><span style='font-size:12px;color:#6d28d9'>string — which Claude version</span>"]
    SYS["<b>system</b><br/><span style='font-size:12px;color:#6d28d9'>string — developer instructions</span>"]
    MSGS["<b>messages list</b><br/><span style='font-size:12px;color:#6d28d9'>list of conversation turns</span>"]
    MSG1["<b>user turn</b><br/><span style='font-size:12px;color:#6d28d9'>role: user — the user prompt text</span>"]
    MSG2["<b>assistant turn</b><br/><span style='font-size:12px;color:#6d28d9'>role: assistant — Claude reply</span>"]
    CLAUDE["<b>Claude on Anthropic server</b><br/><span style='font-size:12px;color:#6d28d9'>reads request, returns response</span>"]

    KEY --> REQ
    REQ --> MODEL
    REQ --> SYS
    REQ --> MSGS
    MSGS --> MSG1
    MSGS --> MSG2
    MSG1 -->|"alternates"| MSG2
    REQ -->|"sent over HTTPS"| CLAUDE

    classDef start fill:#a5d8ff,stroke:#4a9eed
    classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:3
    classDef auto fill:#d0bfff,stroke:#8b5cf6
    classDef act fill:#a5d8ff,stroke:#4a9eed
    classDef done fill:#b2f2bb,stroke:#22c55e
    classDef ghost fill:none,stroke:none,color:#6d28d9

    class KEY act
    class REQ start
    class MODEL act
    class SYS act
    class MSGS auto
    class MSG1 act
    class MSG2 act
    class CLAUDE done
