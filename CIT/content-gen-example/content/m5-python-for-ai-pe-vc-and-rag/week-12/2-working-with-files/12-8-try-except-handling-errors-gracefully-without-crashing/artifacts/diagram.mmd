---
title: "try / except — Handling Errors Without Crashing"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
---
flowchart TD
    TRY["<b>try block</b><br/><span style='font-size:11px;color:#1e3a8a'>code that might fail</span>"]
    RAISED{"<b>exception<br/>raised?</b>"}
    EXCEPT["<b>except block</b><br/><span style='font-size:11px;color:#7f1d1d'>handle the error</span>"]
    ELSE["<b>else block</b><br/><span style='font-size:11px;color:#14532d'>optional — only runs on success</span>"]
    CONT["<b>program continues</b><br/><span style='font-size:11px;color:#312e81'>after try/except</span>"]

    TRY --> RAISED
    RAISED -- "yes" --> EXCEPT
    RAISED -- "no" --> ELSE
    EXCEPT --> CONT
    ELSE --> CONT

    classDef tryNode    fill:#dbeafe,stroke:#3b82f6,color:#1e3a8a
    classDef decision   fill:#fef9c3,stroke:#ca8a04,color:#713f12
    classDef errorPath  fill:#fee2e2,stroke:#ef4444,color:#7f1d1d
    classDef successPath fill:#dcfce7,stroke:#16a34a,color:#14532d
    classDef terminal   fill:#e0e7ff,stroke:#6366f1,color:#312e81

    class TRY tryNode
    class RAISED decision
    class EXCEPT errorPath
    class ELSE successPath
    class CONT terminal
