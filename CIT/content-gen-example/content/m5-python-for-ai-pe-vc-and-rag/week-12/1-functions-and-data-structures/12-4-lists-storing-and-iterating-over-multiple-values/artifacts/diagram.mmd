---
flowchart LR
  subgraph STRUCT["LIST STRUCTURE"]
    direction TB
    S1["<b>List Variable</b><br/><span style='font-size:11px;color:#6d28d9'>marks = [72, 88, 65, 90, 55]</span>"]:::start
    S2["<b>Items by Index</b><br/><span style='font-size:11px;color:#6d28d9'>[0]=72  [1]=88  [2]=65  [3]=90  [4]=55</span>"]:::act
    S3["<b>append() and len()</b><br/><span style='font-size:11px;color:#6d28d9'>add items to end • count items</span>"]:::act
    S1 --> S2 --> S3
  end

  subgraph LOOP["FOR-LOOP TRAVERSAL"]
    direction TB
    L1["<b>Start Iteration</b><br/><span style='font-size:11px;color:#6d28d9'>for mark in marks:</span>"]:::auto
    L2["<b>Current Item</b><br/><span style='font-size:11px;color:#6d28d9'>mark holds one value per pass</span>"]:::auto
    L3["<b>Process Item</b><br/><span style='font-size:11px;color:#6d28d9'>use or accumulate the value</span>"]:::auto
    L4["<b>All Items Visited</b><br/><span style='font-size:11px;color:#6d28d9'>loop ends automatically</span>"]:::done
    L1 --> L2 --> L3 --> L4
  end

  STRUCT -->|"iterate over"| LOOP

