flowchart LR
  subgraph BEFORE["BEFORE — Multi-Job Function"]
    direction TB
    A1["<b>Call Site</b><br/><span style='font-size:11px;color:#6d28d9'>calls process_marks()</span>"]:::callsite
    A2["<b>Phase 1: Compute</b><br/><span style='font-size:11px;color:#6d28d9'>loop totals marks, finds average</span>"]:::multi
