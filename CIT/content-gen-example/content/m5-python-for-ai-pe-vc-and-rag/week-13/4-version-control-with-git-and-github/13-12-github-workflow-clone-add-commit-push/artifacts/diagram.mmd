flowchart LR
    R1["<b>Remote repo</b><br/><span style='font-size:12px;color:#6d28d9'>github.com</span>"]
    L1["<b>Working directory</b><br/><span style='font-size:12px;color:#6d28d9'>edit files here</span>"]
    L2["<b>Staging area</b><br/><span style='font-size:12px;color:#6d28d9'>git add</span>"]
    L3["<b>Local history</b><br/><span style='font-size:12px;color:#6d28d9'>git commit</span>"]
