---
title: "Retry Loop — What to do when validation fails"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 40
    rankSpacing: 50
---
flowchart TD
    A["<b>Call LLM with prompt</b>"]
    B["<b>Run validation check</b>"]
    C{"<b>Response is valid?</b>"}
    D["<b>Return response</b><br/><span style='font-size:12px;color:#6d28d9'>happy path — done</span>"]
    E["<b>Compose corrective message</b><br/><span style='font-size:12px;color:#6d28d9'>corrective message</span>"]
    F["<b>Increment retry counter</b><br/><span style='font-size:12px;color:#6d28d9'>retry counter</span>"]
    G{"<b>Max retries reached?</b>"}
    H["<b>Return fallback response</b><br/><span style='font-size:12px;color:#6d28d9'>fallback response</span>"]

    A --> B
    B --> C
    C -- "<b>Yes ✓</b>" --> D
    C -- "<b>No ✗</b>" --> E
    E --> F
    F --> G
    G -- "<b>No — retry</b>" --> A
    G -- "<b>Yes</b>" --> H

    classDef start fill:#a5d8ff,stroke:#4a9eed
    classDef auto fill:#d0bfff,stroke:#8b5cf6
    classDef done fill:#b2f2bb,stroke:#22c55e
    classDef fallback fill:#ffd8a8,stroke:#f76707

    class A start
    class B,E,F auto
    class D done
    class H fallback
