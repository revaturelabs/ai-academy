%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#a5d8ff", "primaryBorderColor": "#4a9eed", "lineColor": "#555", "fontSize": "15px"}, "flowchart": {"htmlLabels": true, "curve": "basis", "nodeSpacing": 55, "rankSpacing": 65}}}%%
flowchart LR
    classDef start fill:#a5d8ff,stroke:#4a9eed,color:#000
    classDef hitl  fill:#fff3bf,stroke:#f59e0b,stroke-width:3,color:#000
    classDef auto  fill:#d0bfff,stroke:#8b5cf6,color:#000
    classDef act   fill:#a5d8ff,stroke:#4a9eed,color:#000
    classDef done  fill:#b2f2bb,stroke:#22c55e,color:#000

    subgraph MAIN["  Input range: 0 – 100  "]
        direction LR
        EMPTY["<b>Empty input</b><br/><span style='font-size:12px;color:#6d28d9'>[ ] — no marks given</span>"]:::start
        ZERO["<b>Zero (0)</b><br/><span style='font-size:12px;color:#6d28d9'>min value — grade F</span>"]:::start
        NORMAL["<b>Normal zone</b><br/><span style='font-size:12px;color:#6d28d9'>mid values, e.g. 75<br/>no boundary hit</span>"]:::auto
        BOUNDS["<b>Grade boundaries</b><br/><span style='font-size:12px;color:#6d28d9'>exactly 70 / 80 / 90<br/>&gt; vs &gt;= decides grade</span>"]:::hitl
        MAXVAL["<b>Maximum (100)</b><br/><span style='font-size:12px;color:#6d28d9'>max value — grade A</span>"]:::start
        EMPTY --> ZERO --> NORMAL --> BOUNDS --> MAXVAL
    end

    subgraph SIDE["  Test prediction steps  "]
        direction TB
        PREDICT["<b>Write prediction first</b><br/><span style='font-size:12px;color:#6d28d9'>expected output from spec</span>"]:::act
        RUN["<b>Run the code</b><br/><span style='font-size:12px;color:#6d28d9'>use the edge-case input</span>"]:::act
        COMPARE["<b>Compare result</b><br/><span style='font-size:12px;color:#6d28d9'>match = pass, mismatch = bug</span>"]:::done
        PREDICT --> RUN --> COMPARE
    end

    BOUNDS -.->|"test each one"| PREDICT
