---
title: "Where Was the Human Override?"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    primaryTextColor: "#0b1f3a"
    lineColor: "#555"
    fontFamily: "Inter, system-ui, sans-serif"
  flowchart:
    htmlLabels: true
    curve: basis
    nodeSpacing: 28
    rankSpacing: 40
---
flowchart LR
  subgraph MAIN["<b>Admissions Pipeline</b>"]
    direction TB
    app["<b>Application submitted</b>"]:::start
    checks["<b>Completeness + eligibility checks</b><br/><span style='font-size:12px;color:#555'>documents present? GPA meets threshold?</span>"]:::auto
    aiscoring["<b>AI personal qualities scoring</b><br/><span style='font-size:12px;color:#555'>AI produces score</span>"]:::auto
    hitlchk["<b>Human override checkpoint</b><br/><span style='font-size:12px;color:#6d28d9'>holistic review · calibration check</span>"]:::hitl
    final["<b>Final ranking and offer</b>"]:::done

    app --> checks --> aiscoring
    aiscoring -->|"healthy path"| hitlchk --> final
    aiscoring -.->|"override absent / theater"| final
  end

  subgraph SIDE["<b>Functioning Override Point (5 properties)</b>"]
    direction TB
    p12["<b>Defined · Sampled</b><br/><span style='font-size:12px;color:#555'>written in policy · minimum % reviewed</span>"]:::act
    p34["<b>Documented · Empowered</b><br/><span style='font-size:12px;color:#555'>log of reviewer + AI score · no penalty to override</span>"]:::act
    p5["<b>Monitored (rate tracked)</b><br/><span style='font-size:12px;color:#555'>override rate checked on schedule</span>"]:::act

    p12 --> p34 --> p5
  end

  hitlchk -.->|"requires all 5"| SIDE

  classDef start fill:#a5d8ff,stroke:#4a9eed,stroke-width:2px
  classDef auto fill:#d0bfff,stroke:#8b5cf6,stroke-width:2px
  classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:3px
  classDef act fill:#a5d8ff,stroke:#4a9eed,stroke-width:2px
  classDef done fill:#b2f2bb,stroke:#22c55e,stroke-width:2px

  style MAIN fill:none,stroke:#8b5cf6,stroke-dasharray:4 3
  style SIDE fill:#fef9c3,stroke:#f59e0b,stroke-width:2px
