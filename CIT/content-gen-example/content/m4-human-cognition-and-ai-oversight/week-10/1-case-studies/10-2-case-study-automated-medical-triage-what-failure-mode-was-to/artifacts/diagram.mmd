---
config:
  title: "Triage Failure: Tolerated vs Caught"
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
    rankSpacing: 55
    nodeSpacing: 35
---
flowchart LR

  subgraph FAIL["❌ Failure Tolerated"]
    direction TB
    F1["<b>Patient Data</b><br><span style='font-size:12px;color:#6d28d9'>age, symptoms, vitals</span>"]:::start
    F2["<b>AI Priority Score</b><br><span style='font-size:12px;color:#6d28d9'>systematic under-scoring</span>"]:::auto
    F3["<b>Override as Theater</b><br><span style='font-size:12px;color:#6d28d9'>unlogged, rubber-stamp</span>"]:::hitl
    F4["<b>Queue Assignment</b><br><span style='font-size:12px;color:#6d28d9'>wrong priority set</span>"]:::act
    F5["<b>Harm Accumulates</b><br><span style='font-size:12px;color:#6d28d9'>failure tolerated unseen</span>"]:::ghost

    F1 --> F2 --> F3 --> F4 --> F5
  end

  subgraph PASS["✅ Failure Caught"]
    direction TB
    P1["<b>Patient Data</b><br><span style='font-size:12px;color:#6d28d9'>age, symptoms, vitals</span>"]:::start
    P2["<b>AI Priority Score</b><br><span style='font-size:12px;color:#6d28d9'>same model, same risk</span>"]:::auto
    P3["<b>Genuine Override</b><br><span style='font-size:12px;color:#6d28d9'>logged with reason</span>"]:::hitl
    P4["<b>Deterioration Alert</b><br><span style='font-size:12px;color:#6d28d9'>flags wrong score within 120 min</span>"]:::act
    P5["<b>Sub-group Audit</b><br><span style='font-size:12px;color:#6d28d9'>monthly pattern check</span>"]:::done

    P1 --> P2 --> P3 --> P4 --> P5
  end

  FAIL ~~~ PASS

  classDef start fill:#a5d8ff,stroke:#4a9eed
  classDef auto  fill:#d0bfff,stroke:#8b5cf6
  classDef hitl  fill:#fff3bf,stroke:#f59e0b,stroke-width:3px
  classDef act   fill:#a5d8ff,stroke:#4a9eed
  classDef done  fill:#b2f2bb,stroke:#22c55e
  classDef ghost fill:none,stroke:none,color:#6d28d9
