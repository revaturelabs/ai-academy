---
title: "System 1 and System 2 Thinking"
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
---
flowchart LR

  subgraph S1["System 1 — Always On"]
    direction TB
    S1A["<b>Starts automatically</b><br/><span style='font-size:11px;color:#6d28d9'>fast · automatic · parallel</span>"]
    S1B["<b>Produces a candidate answer</b><br/><span style='font-size:11px;color:#6d28d9'>impression or quick response</span>"]
    S1A --> S1B
  end

  GATE{"<b>Trigger<br/>present?</b>"}

  subgraph S2["System 2 — Activated When Needed"]
    direction TB
    T1["<b>Novel situation</b>"]
    T2["<b>Contradiction detected</b>"]
    T3["<b>Complex calculation</b>"]
    T4["<b>High-stakes choice</b>"]
    S2A["<b>System 2 engages</b><br/><span style='font-size:11px;color:#6d28d9'>slow · deliberate · draws on working memory</span>"]
    CAP["<b>Capacity depletes with use</b><br/><span style='font-size:11px;color:#6d28d9'>cognitive fatigue sets in</span>"]
    T1 & T2 & T3 & T4 --> S2A
    S2A -.- CAP
  end

  OUT["<b>Final answer / action</b><br/><span style='font-size:11px;color:#6d28d9'>checked or overridden by System 2</span>"]

  S1B -->|"candidate ready"| GATE
  GATE -->|"yes"| T1
  GATE -->|"yes"| T2
  GATE -->|"yes"| T3
  GATE -->|"yes"| T4
  GATE -->|"no"| OUT
  S2A -->|"check / override"| OUT
  OUT -.->|"refines future responses"| S1A

  classDef start fill:#a5d8ff,stroke:#4a9eed
  classDef auto fill:#d0bfff,stroke:#8b5cf6
  classDef done fill:#b2f2bb,stroke:#22c55e
  classDef ghost fill:none,stroke:none,color:#6d28d9
  classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:3

  class S1A,S1B start
  class GATE hitl
  class T1,T2,T3,T4,S2A auto
  class OUT done
  class CAP ghost
