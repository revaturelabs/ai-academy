    M2["<b>Machine spots repeats</b><br/><span style='font-size:11px;color:#6d28d9'>rule lives inside, often unreadable</span>"]:::auto
    M3["<b>New case</b>"]:::start
    M4["<b>Output</b><br/><span style='font-size:11px;color:#6d28d9'>a likelihood, not a certainty</span>"]:::done
