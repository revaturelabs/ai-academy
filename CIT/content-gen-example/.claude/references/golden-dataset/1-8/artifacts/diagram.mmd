---
title: Tea-Making — Five Standard Shapes
config:
  theme: base
  themeVariables:
    primaryColor: "#a5d8ff"
    primaryBorderColor: "#4a9eed"
    lineColor: "#555"
  flowchart:
    htmlLabels: true
    curve: basis
---
flowchart TD
    A(["<b>Start</b><br/><span style='font-size:11px;color:#6d28d9'>terminator — oval</span>"]):::start
    B["<b>Switch kettle on</b><br/><span style='font-size:11px;color:#6d28d9'>process — rectangle</span>"]:::act
    C{"<b>Water boiled?</b><br/><span style='font-size:11px;color:#6d28d9'>decision — diamond</span>"}:::hitl
    D["<b>Wait 30 seconds</b><br/><span style='font-size:11px;color:#6d28d9'>process — loops back</span>"]:::act
    E["<b>Pour water in cup</b><br/><span style='font-size:11px;color:#6d28d9'>process — rectangle</span>"]:::act
    F[/"<b>Serve the tea</b><br/><span style='font-size:11px;color:#6d28d9'>output — parallelogram</span>"/]:::auto
    G(["<b>End</b><br/><span style='font-size:11px;color:#6d28d9'>terminator — oval</span>"]):::done

    A --> B
    B --> C
    C -- No --> D
    D --> C
    C -- Yes --> E
    E --> F
    F --> G

    classDef start fill:#a5d8ff,stroke:#4a9eed,stroke-width:2px
    classDef act fill:#a5d8ff,stroke:#4a9eed,stroke-width:2px
    classDef auto fill:#d0bfff,stroke:#8b5cf6,stroke-width:2px
    classDef hitl fill:#fff3bf,stroke:#f59e0b,stroke-width:3px
    classDef done fill:#b2f2bb,stroke:#22c55e,stroke-width:2px
